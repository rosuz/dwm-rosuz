* {
    font: "JetbrainsMono Nerd Font 12";

    /* Base colors */
    bg0: {{ background }};
    bg1: {{ color0 }};
    fg0: {{ foreground }};
    
    /* Accent colors */
    accent-color: {{ accent }};

    /* Placeholders */
    current-image: none;
    
    /* Base properties */
    background-color: transparent;
}
