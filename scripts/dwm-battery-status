#!/bin/bash

set -euo pipefail

BATTERY="$(upower -e | grep -m1 battery || true)"

[[ -n "$BATTERY" ]] || {
  notify-send "Battery" "No battery found"
  exit 0
}

INFO="$(upower -i "$BATTERY")"

STATE="$(awk -F': *' '/state/ {print $2}' <<< "$INFO")"
PCT="$(awk -F': *' '/percentage/ {gsub("%","",$2); print $2}' <<< "$INFO")"
TIME="$(awk -F': *' '/time to empty/ {print $2}' <<< "$INFO")"

notify-send "Battery" "State: $STATE
Charge: ${PCT}%
Remaining: $TIME"
