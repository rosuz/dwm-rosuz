#!/usr/bin/env bash
set -euo pipefail

DWM_PATH="$(cd "$(dirname "$0")/.." && pwd)"
LOCKER="$DWM_PATH/scripts/dwm-lock-screen"

LOCK_FILE="/tmp/dwm-xautolock.lock"
STATE_DIR="$HOME/.local/state/dwm/indicators"
STATE_FILE="$STATE_DIR/idle"

IDLE_MINUTES=5
quiet="false"
for arg in "$@"; do
  if [[ "$arg" == "--quiet" ]]; then
    quiet="true"
  fi
done

mkdir -p "$STATE_DIR"

exec 9>"$LOCK_FILE"
flock -n 9 || exit 0

is_running() {
  pgrep -x xautolock >/dev/null
}

enable_idle() {
  if is_running; then
    echo "enabled" > "$STATE_FILE"
    return
  fi

  local timeout=$((IDLE_MINUTES * 60))

  xset s "$timeout" "$timeout"
  xset +dpms
  xset s blank

  xautolock \
    -time "$IDLE_MINUTES" \
    -locker "$LOCKER" \
    -detectsleep 9>&- &

  sleep 0.3
  is_running && echo "enabled" > "$STATE_FILE" || echo "disabled" > "$STATE_FILE"
  if [[ "$quiet" != "true" ]]; then
    notify-send "Idle" "Auto-lock enabled (${IDLE_MINUTES} min)"
  fi
}

disable_idle() {
  pkill -x xautolock 2>/dev/null || true

  xset s off
  xset -dpms
  xset s noblank

  echo "disabled" > "$STATE_FILE"
  notify-send "Idle" "Auto-lock disabled"
}

case "${1:-toggle}" in
  --enable)
    enable_idle
    ;;
  --disable)
    disable_idle
    ;;
  *)
    if is_running; then
      disable_idle
    else
      enable_idle
    fi
    ;;
esac
